# ─── SilentTalk Frontend — Environment Variables ─────────────────────────────
# Copy this file to .env.local for local development
# Set these as Environment Variables in Vercel dashboard for production

# Backend API URL (Render service URL in production, e.g. https://silenttalk-api.onrender.com)
VITE_API_URL=https://your-backend.onrender.com
